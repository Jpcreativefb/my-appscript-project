function getUsersSheet_(){

  const sh =
    SpreadsheetApp
      .getActive()
      .getSheetByName(
        USERS_SHEET
      );

  if (!sh) {

    throw new Error(
      "Users sheet not found"
    );

  }

  return sh;

}

function getAllUsersData_(){

  return getUsersSheet_()
    .getDataRange()
    .getValues();

}

function appendUserRow_(row){

  getUsersSheet_()
    .appendRow(row);

}